<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="ru.alesya0711.laba6.view.controllers.AssignmentDialogController"
      spacing="15.0"
      style="-fx-padding: 20;">

    <Label fx:id="dialogTitleLabel" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="%addAssigment.title"/>

    <GridPane hgap="10.0" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="120.0"/>
            <ColumnConstraints minWidth="250.0"/>
        </columnConstraints>

        <Label text="%addAssigment.student" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="studentComboBox" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="%addAssigment.name" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="assignmentNameField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="%addAssigment.data" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <DatePicker fx:id="assignmentDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="%addAssigment.grade" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <Spinner fx:id="gradeSpinner" editable="true" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="%addAssigment.status" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <ComboBox fx:id="statusComboBox" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button fx:id="saveButton" defaultButton="true" onAction="#saveAssignment" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="%addAssigment.save"/>
        <Button cancelButton="true" onAction="#cancel" text="%addAssigment.cansel"/>
    </HBox>
</VBox>