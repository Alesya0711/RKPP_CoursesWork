<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
            fx:controller="ru.alesya0711.laba6.view.controllers.LoginController"
            style="-fx-background-color: #f0f0f0;">
    <top>
        <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10;">
            <Label fx:id="languageLabel" text="%app.language"/>
            <ComboBox fx:id="languageComboBox" prefWidth="150"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 40;">
            <Label fx:id="titleLabel" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="%login.title"/>
            <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" spacing="10">
                <TextField fx:id="usernameField" promptText="%login.username"/>
                <PasswordField fx:id="passwordField" promptText="%login.password"/>
                <Button fx:id="loginButton" onAction="#handleLogin" text="%login.button" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" prefWidth="200"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>